{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "server/api/research.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/research",
      "dest": "server/api/research.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}